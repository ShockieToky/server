# ============================================================
# Template pour les variables de production
# Copie ce fichier en ".env.local" sur le serveur de prod
# et remplis chaque valeur.
# Ce fichier ne doit PAS être commité avec de vraies valeurs.
# ============================================================

###> symfony/framework-bundle ###
APP_ENV=prod
APP_DEBUG=0
# Génère une nouvelle valeur : php -r "echo bin2hex(random_bytes(32));"
APP_SECRET=CHANGE_ME_32_CHAR_HEX
###< symfony/framework-bundle ###

###> symfony/routing ###
# L'URL complète de ton API backend en prod
DEFAULT_URI=https://api.projethintedum.fr
###< symfony/routing ###

###> lexik/jwt-authentication-bundle ###
# Génère une nouvelle valeur : php -r "echo bin2hex(random_bytes(32));"
JWT_SECRET_KEY=CHANGE_ME_64_CHAR_HEX
###< lexik/jwt-authentication-bundle ###

###> doctrine/doctrine-bundle ###
# Adapte avec tes identifiants MySQL de prod
DATABASE_URL="mysql://DB_USER:DB_PASSWORD@127.0.0.1:3306/revolution_hintedum?serverVersion=8.0.32&charset=utf8mb4"
###< doctrine/doctrine-bundle ###

###> nelmio/cors-bundle ###
# Remplace par l'URL exacte de ton frontend (sans slash final)
CORS_ALLOW_ORIGIN='^https://(www\.)?projethintedum\.fr$'
###< nelmio/cors-bundle ###
